<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/image_thumbnail"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Selection overlay (dim effect when selected) -->
    <View
        android:id="@+id/selectionOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/selection_overlay"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/imageView"
        app:layout_constraintBottom_toBottomOf="@id/imageView"
        app:layout_constraintStart_toStartOf="@id/imageView"
        app:layout_constraintEnd_toEndOf="@id/imageView" />

    <!-- Checkmark icon (top-right when selected) -->
    <ImageView
        android:id="@+id/checkMark"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_margin="4dp"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone"
        android:contentDescription="@string/selected"
        app:tint="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="@id/imageView"
        app:layout_constraintEnd_toEndOf="@id/imageView" />

    <!-- Warning icon for items hidden by filter (top-right, orange) -->
    <ImageView
        android:id="@+id/warningIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_margin="4dp"
        android:src="@drawable/ic_warning"
        android:visibility="gone"
        android:contentDescription="@string/hidden_by_filter"
        app:layout_constraintTop_toTopOf="@id/imageView"
        app:layout_constraintEnd_toEndOf="@id/imageView" />

    <!-- Video indicator icon (top-left) -->
    <ImageView
        android:id="@+id/videoIndicator"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="4dp"
        android:src="@drawable/ic_play_circle"
        android:visibility="gone"
        android:contentDescription="@string/video_indicator"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="@id/imageView"
        app:layout_constraintStart_toStartOf="@id/imageView" />

    <!-- Source badge (bottom-left) -->
    <TextView
        android:id="@+id/sourceBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:background="@drawable/badge_bg_unviewed"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:textColor="@color/badge_unviewed_text"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@id/imageView"
        app:layout_constraintStart_toStartOf="@id/imageView" />

</androidx.constraintlayout.widget.ConstraintLayout>
